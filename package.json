{
  "name": "electron-vue-app",
  "version": "1.0.4",
  "private": true,
  "description": "风险治理系统",
  "author": "your-name",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:web && npm run build:electron",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "element-plus": "^2.13.5",
    "pinia": "^3.0.4",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26"
  },
  "build": {
    "appId": "com.risk.app",
    "productName": "风险治理",
    "asar": true,
    "compression": "maximum",
    "publish": [
      {
        "provider": "github"
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "electronLanguages": [
      "en"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "!src",
      "!node_modules/.cache",
      "!**/*.map",
      "!*.log",
      "!*.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "type": "distribution"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowElevation": true
    }
  }
}
